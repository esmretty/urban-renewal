# 必填：Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# 選填：Google Maps Geocoding API (較精確，否則用 Nominatim 免費服務)
GOOGLE_MAPS_API_KEY=

# 選填：TGOS 國土測繪中心 API Key (台灣政府地理資訊)
TGOS_API_KEY=

# 新屋市價假設（元/坪），可依地段調整，預設台北市均值
DEFAULT_NEW_HOUSE_PRICE_PER_PING=1200000

# 建設成本（元/坪）
CONSTRUCTION_COST_PER_PING=180000

# Firebase Web API Key（前端 Google 登入用；可從 Firebase console > Project settings > Your apps 取得）
FIREBASE_WEB_API_KEY=
FIREBASE_APP_ID=

# 可登入 admin 後台的 email 清單（逗號分隔，大小寫不敏感）
# OWNER 權限最高；SYSTEM_ADMIN 次之。兩者都能進 admin 後台
# 把自己的 Gmail 填進來（用來 Firebase Auth Google 登入 → 後台自動識別為 admin）
OWNER_EMAILS=you@example.com
SYSTEM_ADMIN_EMAILS=admin1@example.com,admin2@example.com

# 單筆 URL 分析併發上限（預設 4；每個 task 約吃 300MB RAM + Playwright browser context）
# 可承受：4GB RAM 機器 → 3~4；8GB → 5~6；16GB+ → 8~10（>6 開始撞 Claude rate limit）
# 調高：可同時服務更多用戶；調低：省資源。批次抓取獨立不受此影響
MAX_URL_CONCURRENCY=4

# 定時 batch 完全用 admin UI 設定（存 Firestore settings/scheduler）：
# - 啟用/停用、interval、每個命令的區域和筆數都在 UI 調
# - 第一次啟動（Firestore 沒 doc）的預設值在 config.SCHEDULED_SCRAPE_* 常數
